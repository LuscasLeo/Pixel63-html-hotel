{
    "configurations": [
        {
            "name": "Attach to Editor Browser",
            "request": "attach",
            "type": "editor-browser",
            "webRoot": "${workspaceFolder}/packages/${input:packageName}",
            "sourceMaps": true
        },
        {
            "name": "Attach to Google Chrome",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}/packages/${input:packageName}",
            "sourceMaps": true
        },
        {
            "type": "node-terminal",
            "name": "Run Script: start (server)",
            "request": "launch",
            "command": "pnpm run start",
            "cwd": "${workspaceFolder}/packages/server",
            "sourceMaps": true
        }
    ],
    "inputs": [
        {
            "id": "packageName",
            "type": "pickString",
            "description": "Select the package to attach to",
            "options": [
                "game",
                "web"
            ]
        }
    ]
}